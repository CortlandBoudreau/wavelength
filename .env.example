# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email addresses
EMAIL_TO=recipient@example.com
EMAIL_FROM=sender@yourdomain.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/wavelength

# Server
PORT=3001
NODE_ENV=development

# JWT secret for auth — MUST be at least 32 chars, never the placeholder
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Admin secret for manually triggering aggregation (POST /api/stories/refresh)
# Pass as header: X-Admin-Secret: <value>
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# Optional: set to "false" only if your DB host uses self-signed certs (not recommended)
# DB_SSL_REJECT_UNAUTHORIZED=false

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# RevenueCat webhook shared secret
# Set in RevenueCat dashboard: Project → Webhooks → Authorization header value
# Leave blank to skip verification (dev only)
REVENUECAT_WEBHOOK_SECRET=

# RevenueCat SECRET API key (server-side only — never expose to client)
# Used to verify purchases server-side in /api/subscription/revenuecat-sync
# RevenueCat dashboard: Project → API Keys → Secret keys
REVENUECAT_SECRET_KEY=
