# ── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For local dev, the API URL below works with `npm run dev` in the server/ dir.
# On Android Emulator use 10.0.2.2 (host loopback); on a physical device use
# your machine's LAN IP (e.g. http://192.168.1.x:3001/api).

EXPO_PUBLIC_API_URL=http://localhost:3001/api

# RevenueCat — Android public API key
# Get from: app.revenuecat.com → Project → API Keys → Public app-specific keys (Android)
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google OAuth — Web client ID (used by expo-auth-session for Google Sign-In)
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Create a "Web application" OAuth 2.0 Client ID, then add these Authorized Redirect URIs:
#   https://auth.expo.io/@cboudreaus-organization/wavelength   ← Expo Go / dev
#   wavelength://                                               ← standalone APK/AAB
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── EAS Build profiles (set automatically via eas.json — do not set here) ────
#
# preview     → APP_ENV=staging     → https://wavelength-staging.up.railway.app/api
# production  → APP_ENV=production  → https://wavelength-production-de44.up.railway.app/api
#
# Build commands:
#   Staging APK (sideload/internal):  eas build --profile preview --platform android
#   Production bundle (Play Store):   eas build --profile production --platform android
